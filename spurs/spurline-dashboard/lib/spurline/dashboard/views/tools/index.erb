<h2>Registered Tools</h2>

<% unless @spur_registry.empty? %>
  <h3 style="font-size:14px;color:#6b7280;margin-bottom:8px">Loaded Spurs</h3>
  <table style="margin-bottom:24px">
    <thead>
      <tr>
        <th>Spur</th>
        <th>Tools</th>
        <th>Default Trust</th>
        <th>Requires Confirmation</th>
      </tr>
    </thead>
    <tbody>
      <% @spur_registry.each do |name, info| %>
        <tr>
          <td><%= escape_html(name) %></td>
          <td><%= info[:tools].map { |t| escape_html(t) }.join(', ') %></td>
          <td><%= info[:permissions][:default_trust] ? trust_badge(info[:permissions][:default_trust]) : '--' %></td>
          <td><%= info[:permissions][:requires_confirmation] ? 'Yes' : 'No' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<h3 style="font-size:14px;color:#6b7280;margin-bottom:8px">Tool Registry</h3>

<% if @tool_registry.empty? %>
  <div class="empty-state">No tools registered.</div>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Class</th>
        <th>Description</th>
        <th>Confirmation</th>
        <th>Idempotent</th>
      </tr>
    </thead>
    <tbody>
      <% @tool_registry.each do |name, info| %>
        <tr>
          <td><strong><%= escape_html(name) %></strong></td>
          <td><%= escape_html(info[:class_name]) %></td>
          <td><%= escape_html(truncate_text(info[:description], length: 120)) %></td>
          <td><%= info[:requires_confirmation] ? 'Yes' : 'No' %></td>
          <td><%= info[:idempotent] ? 'Yes' : 'No' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
